{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build API (TypeSpec)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "cwd": "${workspaceFolder}/docs/api/typespec",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Run Backend (Spring Boot)",
      "type": "java",
      "request": "launch",
      "mainClass": "com.callscalendar.CallsCalendarApplication",
      "projectName": "backend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "javaHome": "/Library/Java/JavaVirtualMachines/jdk-21.jdk/Contents/Home",
      "preLaunchTask": "Run Backend"
    },
    {
      "name": "Run Frontend (Angular)",
      "type": "node",
      "request": "launch",
      "task": "Run Frontend"
    }
  ]
}
